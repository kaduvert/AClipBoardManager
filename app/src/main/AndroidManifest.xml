<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Custom signature-level permission guarding writes to our ContentProvider bridge.
         Third-party apps can never hold this (different signing cert). system_server
         (the LSPosed hook's host process) always passes permission checks because it
         runs as the SYSTEM uid, which Android's permission checker treats as trusted. -->
    <permission
        android:name="com.clipvault.app.permission.WRITE_CLIP"
        android:protectionLevel="signature" />

    <!-- Only meaningful if this APK is ever promoted to a priv-app via the bundled
         Magisk module (see /magisk-module). Ignored otherwise - no normal permission
         prompt is shown for it and no ordinary functionality depends on it. -->
    <uses-permission android:name="android.permission.READ_CLIPBOARD_IN_BACKGROUND"
        tools:ignore="ProtectedPermissions" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".ClipVaultApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:description="@string/xposed_description"
        android:roundIcon="@mipmap/ic_launcher"
        android:theme="@style/Theme.ClipVault"
        android:enableOnBackInvokedCallback="true"
        android:supportsRtl="true">

        <!-- Classic-API (rovo89-style, API 82) module discovery - read by
             frameworks that don't understand the modern libxposed API at all.
             The modern API (see ClipboardHookModern) doesn't use manifest
             metadata; its equivalents are the META-INF/xposed/* files. -->
        <meta-data android:name="xposedmodule" android:value="true" />
        <meta-data android:name="xposedminversion" android:value="93" />
        <meta-data android:name="xposeddescription" android:value="@string/xposed_description" />
        <meta-data android:name="xposedscope" android:resource="@array/xposed_scope" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ClipVault"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Bridge ContentProvider: the only way clip data crosses from the LSPosed
             hook (running inside system_server) into this app's process/database. -->
        <provider
            android:name=".provider.ClipboardProvider"
            android:authorities="com.clipvault.app.provider"
            android:exported="true"
            android:writePermission="com.clipvault.app.permission.WRITE_CLIP"
            android:readPermission="com.clipvault.app.permission.WRITE_CLIP" />

        <service
            android:name=".root.ClipboardWatcherService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Local clipboard history capture (root/priv-app mode only)" />
        </service>

    </application>
</manifest>
